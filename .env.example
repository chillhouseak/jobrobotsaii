# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/jobrobots_ai

# JWT Secret (use a strong random string)
JWT_SECRET=jobrobots_secret_key_2024_production

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Frontend URL (for password reset email links)
FRONTEND_URL=https://jobrobotsai.vercel.app

# Email / SMTP (for password reset emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

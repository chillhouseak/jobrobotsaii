{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/index.js" },
    { "src": "/health", "dest": "/index.js" },
    { "src": "/(.*)", "status": 302, "headers": { "Location": "https://jobrobotsaii-qbjo.vercel.app" } }
  ]
}
